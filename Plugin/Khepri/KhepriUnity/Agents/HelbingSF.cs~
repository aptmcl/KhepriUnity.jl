using System.Collections;
using System.Collections.Generic;
using UnityEngine;
using UnityEngine.AI;
using Unity.AI.Navigation;

namespace KhepriUnity {

    public class HelbingSF : IMovement {
        public Agent_ agent;

        public float mass = 1.0f;

        public float relaxationTime = 0.5f; // tau_alpha
        public float maximumSpeedCoef = 1.3f;

        // Desired Direction
        public Vector3 desiredDirection; // e_a(t)
        public float desiredSpeed; // v_alpha_0

        // Repulsive Forces with Agents
        public float V = 2.1f; // V_alpha_Beta_0
        public float sigma = 0.3f;

        // Repulsive Forces with Walls
        public float U = 10.0f; // U_alpha_B_0
        public float R = 0.2f;

        // Direction Weights
        public float c = 0.5f;
        public float phi = 100f; // = 5pi/9

        public float currentSpeed = 0.0f;
        public Vector3 currentVelocity = Vector3.zero;

        private NavMeshPath path;
        private float elapsed = 0.0f; // related to vis vectors

        public HelbingSF(
            float relaxationTime, float maximumSpeedCoef,
            float V, float sigma,
            float U, float R,
            float c, float phi,
            float desiredSpeed) {
            this.relaxationTime = relaxationTime;
            this.maximumSpeedCoef = maximumSpeedCoef;
            this.V = V;
            this.sigma = sigma;
            this.U = U;
            this.R = R;
            this.c = c;
            this.phi = phi;

            this.desiredSpeed = desiredSpeed;

            path = new NavMeshPath();
            elapsed = 0.0f;
        }

        public void SetAgent(Agent_ agent) {
            this.agent = agent;
        }

        // Update is called once per frame
        public Vector3 Move(float deltaTime, float impacience) {
            // Velocity update
            if (agent.characterController.velocity.x > 0.05f || agent.characterController.velocity.z > 0.05f) {
                currentVelocity = new Vector3(agent.characterController.velocity.x, 0.0f, agent.characterController.velocity.z);
            }

            // Update the way to the goal every second.
            elapsed += deltaTime;
            if (true) //(elapsed > 1.0f)
            {
                elapsed -= 1.0f;
                NavMesh.CalculatePath(agent.transform.position, agent.goal.position, NavMesh.AllAreas, path);
                // Update desired direction
                if (path.corners.Length >= 2) {
                    desiredDirection = (path.corners[1] - path.corners[0]).normalized;
                    /*
                    for (int i = 0; i < path.corners.Length - 1; i++)
                        Debug.DrawLine(path.corners[i], path.corners[i + 1], Color.red);
                    */
                } else {
                    desiredDirection = (agent.goal.position - agent.transform.position).normalized;
                    /*
                    Debug.DrawLine(agent.transform.position, agent.goal.position, Color.green);
                    */
                }
            }

            /*
            for (int i = 0; i < path.corners.Length - 1; i++)
                Debug.DrawLine(path.corners[i], path.corners[i + 1], Color.red);
            */

            // Update velocity based on social forces model
            currentVelocity = UpdateVelocity(deltaTime, impacience);
            return currentVelocity * deltaTime;
        }

        private Vector3 DesiredVelocityForce() // _F_alpha_0
        {
            return (desiredSpeed * desiredDirection - currentVelocity) / relaxationTime;
        }

        private Vector3 RepulsiveForceAgent(Vector3 raB, Vector3 sB) {
            Vector3 v = raB - sB;
            float W = Mathf.Sqrt(Mathf.Pow(raB.magnitude + v.magnitude, 2f) -
                sB.sqrMagnitude) / 2; //2b
            Vector3 force = V / (2.0f * sigma * W) * Mathf.Exp(-W / (2.0f * sigma)) *
                (raB.magnitude + v.magnitude) * (raB.normalized + v.normalized);

            return DirectionWeights(desiredDirection, force) * force;
        }

        private Vector3 RepulsiveForceAgentsTotal(float deltaTime) {
            Vector3 totalForce = Vector3.zero;

            foreach (Agent_ a in agent._nearbyAgents.Values) {
                Vector3 rB = a.transform.position;
                Vector3 sB = a.velocityPrev * deltaTime;
                totalForce += RepulsiveForceAgent(agent.transform.position - rB, sB);
            }

            return totalForce;
        }

        private Vector3 RepulsiveForceObstacle(Vector3 raB) // _F_alpha_B
        {
            return U / R * Mathf.Exp(-raB.magnitude / R) * raB.normalized;
        }

        private Vector3 RepulsiveForceObstaclesTotal() {
            Vector3 totalForce = Vector3.zero;
            Vector3 closest = Vector3.zero;
            float closestDistance = float.MaxValue;

            foreach (Vector3 obstacle in agent.closestPTSObstacles) {
                float distance = (agent.transform.position - obstacle).sqrMagnitude;
                if (distance < closestDistance) {
                    closestDistance = distance;
                    closest = obstacle;
                }
            }

            return RepulsiveForceObstacle(agent.transform.position - closest);
        }

        public float DirectionWeights(Vector3 e, Vector3 f) {
            if (Vector3.Dot(e, f) < f.magnitude * Mathf.Cos(phi))
                return 1.0f;
            else
                return c;
        }

        public float G(float desSpeed) {
            float vAMax = maximumSpeedCoef * desiredSpeed;
            if (desSpeed <= vAMax)
                return 1.0f;
            else
                return vAMax / desSpeed;
        }

        // a>0 controls how quicly it rises, with higher values meaning steeper rises
        public float exp_increase(float k, float a)
        {
            return (1 - Mathf.Exp(-a * k)) / (1 - Mathf.Exp(-a));
        }

        // a>0 controls the curvature. Lower values smoother curver, higher values steeper curves
        public float log_increase(float k, float a)
        {
            return Mathf.Log(1 + a * k) / Mathf.Log(1 + a);
        }

        public Vector3 UpdateVelocity(float deltaTime, float impatience)
        {
            Vector3 force0 = DesiredVelocityForce();
            force0 += log_increase(impatience, 10) * force0 / 2;

            Vector3 force1 = RepulsiveForceAgentsTotal(deltaTime);
            force1 -= exp_increase(impatience, 1) * force1 / 2;

            Vector3 force2 = RepulsiveForceObstaclesTotal();
            force2 -= log_increase(impatience, 10) * force2 / 2;

            Vector3 totalForce = force0 + force1 + force2;
            Vector3 preferedVelocity = currentVelocity + (totalForce / mass) * deltaTime;
            preferedVelocity *= G(preferedVelocity.magnitude);
            return new Vector3(preferedVelocity.x, 0.0f, preferedVelocity.z);
        }
